                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                            <span class="code-window-title">developer.cs</span>
                        </div>
                        <div class="code-window-body">
                            <pre><code><span class="kw">public class</span> <span class="cl">Developer</span>
{
    <span class="kw">public string</span> Name => <span class="st">"Ahmed"</span>;
    <span class="kw">public string</span> Role => <span class="st">"Lead Doc Controller"</span>;
    <span class="kw">public string[]</span> Skills =>
    [
        <span class="st">"C#"</span>, <span class="st">"ASP.NET Core 8"</span>,
        <span class="st">"SQL Server"</span>, <span class="st">"Azure"</span>
    ];
}</code></pre>
                        </div>
