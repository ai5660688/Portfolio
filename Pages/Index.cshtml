                    <div class="stat-item">
                        <div class="stat-number" data-target="@((int)((DateTime.Now - new DateTime(2013, 6, 1)).TotalDays / 365.25))">@((int)((DateTime.Now - new DateTime(2013, 6, 1)).TotalDays / 365.25))+</div>
